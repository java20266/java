<%@ include file="logic.jsp" %>
<html>
<head>
    <title>Perfect Number Check</title>
</head>
<body>

<h2 align="center">Perfect Number Check</h2>

<%
    int num = 28; // You can change the number
    int sum = 0;

    // Logic to check perfect number
    for (int i = 1; i < num; i++) {
        if (num % i == 0) {
            sum += i;
        }
    }

    String result;
    if (sum == num) {
        result = num + " is a Perfect Number";
    } else {
        result = num + " is NOT a Perfect Number";
    }
%>

<h3 style="color:blue;" align="center">
    <%= result %>
</h3>

</body>
</html>
