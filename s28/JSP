  <%@ page import="java.io.*" %>
<html>
<body>

<form method="post">
    Enter String: <input type="text" name="str">
    <input type="submit" value="Reverse">
</form>

<%
    String input = request.getParameter("str");

    if (input != null) {
        String reversed = "";

        for (int i = input.length() - 1; i >= 0; i--) {
            reversed += input.charAt(i);
        }

        out.println("<h3>Reversed String: " + reversed + "</h3>");
    }
%>

</body>
</html>
